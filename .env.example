# ──────────────────────────────────────────────────────────────
#  BMPT Solutions Website — environment variables
#  Copy this file to `.env` and fill in real values.
# ──────────────────────────────────────────────────────────────

# ── Database (dedicated PostgreSQL DB for this website only) ────
# Local:
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bmptsolutions_website?schema=public&connection_limit=5"
# `connection_limit=5` keeps this app's Postgres pool small (good on shared
# local Postgres and on managed hosts with a per-app limit). Increase for prod.
# Server example (managed Postgres / Neon / RDS):
# DATABASE_URL="postgresql://USER:PASSWORD@db-host:5432/bmptsolutions_website?sslmode=require"

# ── Redis (response/content cache) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── NextAuth (admin authentication) ────────────────────────────
NEXTAUTH_SECRET="change-me-to-a-random-string-at-least-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# ── AWS S3 (media for the public website) ──────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET_NAME="bmptsolutions-website-media"
AWS_S3_BASE_URL="https://bmptsolutions-website-media.s3.us-east-1.amazonaws.com"

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="BMPT Solutions"

# ── Seed admin (used by `npm run db:seed` to create first admin) ─
SEED_ADMIN_EMAIL="bmptsolutions10@gmail.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="BMPT Admin"
